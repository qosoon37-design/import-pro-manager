# Backend Environment Variables - Copy to .env and fill in values
DATABASE_URL="postgresql://user:password@localhost:5432/erp_inventory"
JWT_SECRET="change-this-to-a-long-random-secret-at-least-64-chars"
JWT_REFRESH_SECRET="change-this-too-another-long-random-secret"
JWT_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WHATSAPP_TO="whatsapp:+1234567890"

# Google Vision API (optional)
GOOGLE_APPLICATION_CREDENTIALS=""
